rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }
    function isStaff() {
      return isSignedIn() && (role() == 'admin' || role() == 'ca');
    }
    function isAllowedBillFile() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/jpeg|image/jpg|image/png');
    }

    // Scanned purchase/sales bills. Only the admin uploads; both roles can
    // view/download since the CA needs to review them.
    match /purchases/{purchaseId}/{fileName} {
      allow read: if isStaff();
      allow write: if isAdmin() && isAllowedBillFile();
    }

    match /sales/{saleId}/{fileName} {
      allow read: if isStaff();
      allow write: if isAdmin() && isAllowedBillFile();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
