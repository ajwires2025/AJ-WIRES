rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }
    function isCA() {
      return isSignedIn() && role() == 'ca';
    }
    function isStaff() {
      return isAdmin() || isCA();
    }

    // User directory (admin/ca accounts). Managing who can log in stays
    // admin-only; both roles can read the directory to show names in the UI.
    match /users/{userId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Master data: customers/suppliers and the item catalog.
    // Both Admin and CA have full read/write access.
    match /parties/{partyId} {
      allow read, write: if isStaff();
    }

    match /items/{itemId} {
      allow read, write: if isStaff();
    }

    // Purchase bills. Both Admin and CA have full read/write access.
    match /purchases/{purchaseId} {
      allow read, write: if isStaff();
    }

    // Sales invoices. Same access pattern as purchases.
    match /sales/{saleId} {
      allow read, write: if isStaff();
    }

    // Sequential invoice-number counters, one doc per financial year.
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }

    // Payments against purchase bills and sales invoices.
    match /payments/{paymentId} {
      allow read, write: if isStaff();
    }

    // Day-to-day expenses and other income — not tied to a purchase/sales bill.
    match /expenses/{expenseId} {
      allow read, write: if isStaff();
    }

    // Manual double-entry journal vouchers (closing adjustments, provisions,
    // depreciation, write-offs, etc.).
    match /journalVouchers/{voucherId} {
      allow read, write: if isStaff();
    }

    // Sales returns / invoice reductions issued to customers.
    match /creditNotes/{noteId} {
      allow read, write: if isStaff();
    }

    // Purchase returns / bill reductions issued to suppliers.
    match /debitNotes/{noteId} {
      allow read, write: if isStaff();
    }

    // Raw material -> finished good production entries.
    match /productionVouchers/{voucherId} {
      allow read, write: if isStaff();
    }

    // Manual corrections to the auto-computed GST Summary (reverse charge,
    // ITC reversal, TDS/TCS, rounding, etc).
    match /gstAdjustments/{adjustmentId} {
      allow read, write: if isStaff();
    }

    // Pre-invoice offers to customers / pre-bill commitments to suppliers.
    match /quotations/{quotationId} {
      allow read, write: if isStaff();
    }
    match /purchaseOrders/{poId} {
      allow read, write: if isStaff();
    }

    // Fixed asset register (depreciation schedule computed client-side).
    match /fixedAssets/{assetId} {
      allow read, write: if isStaff();
    }

    // Log of every reminder email sent (or attempted) — written by the
    // server-side send API using the Admin SDK, but readable here so the UI
    // can show history.
    match /remindersLog/{logId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // App-wide settings (e.g. reminder due-soon-days threshold).
    match /settings/{settingId} {
      allow read, write: if isStaff();
    }

    // Everything else is denied by default until explicitly opened up.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
